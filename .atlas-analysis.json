  "keyFeatures": [
    "OAuth2 authentication with multiple providers",
    "Hacker application and acceptance system",
    "Application review and grading workflow",
    "Project judging with rubric-based scoring",
    "QR code meal tickets and event check-in",
    "Equipment checkout and tracking",
    "Event scheduling and timeslot management",
    "Role-based access control for multiple user types",
    "Admin dashboard for organizer management",
    "Integration with SendGrid, PostHog, and AWS S3"
  ],
